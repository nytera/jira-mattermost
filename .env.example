MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=replace-with-bot-personal-access-token
MATTERMOST_ALERT_CHANNEL_ID=alerts-channel-id
MATTERMOST_INCIDENT_CHANNEL_ID=incidents-channel-id
MATTERMOST_INCIDENT_REACTION_NAME=incident
MATTERMOST_BOT_USER_ID=bot-user-id

JIRA_BASE_URL=https://jira.example.com
JIRA_EMAIL=bot@example.com
JIRA_API_TOKEN=replace-with-jira-personal-access-token
JIRA_AUTH_TYPE=bearer
JIRA_REST_API_VERSION=2
JIRA_PROJECT_KEY=OPS
JIRA_ISSUE_TYPE=Incident
JIRA_VALID_INCIDENT_FIELD=Валидность
JIRA_SOURCE_FIELD=Источник
JIRA_IS_CRIT_ALERT_FIELD=Был ли крит алерт?
JIRA_CONFIRMED_STATUS_ID=

DATABASE_URL=sqlite:///./mattermost_jira_bot.db
INCIDENT_TIMEZONE=Europe/Moscow

# Optional hardening and runtime tuning.
MATTERMOST_SLASH_TOKEN=
LOG_LEVEL=INFO
API_RETRY_ATTEMPTS=4
API_RETRY_BASE_DELAY_SECONDS=0.5
PENDING_WORK_INTERVAL_SECONDS=30
BACKFILL_RECENT_POSTS_LIMIT=0
ENABLE_BACKFILL_ON_STARTUP=false
