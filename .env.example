MATTERMOST_URL=https://mattermost.example.com
MATTERMOST_TOKEN=replace-with-bot-personal-access-token
MATTERMOST_ALERT_CHANNEL_ID=alerts-channel-id
MATTERMOST_INCIDENT_CHANNEL_ID=incidents-channel-id
MATTERMOST_INCIDENT_REACTION_NAME=incident
MATTERMOST_BOT_USER_ID=bot-user-id

JIRA_BASE_URL=https://jira.example.com
JIRA_API_TOKEN=replace-with-jira-personal-access-token
JIRA_PROJECT_KEY=OPS
JIRA_ISSUE_TYPE=Incident
JIRA_VALID_INCIDENT_FIELD=Валидность
JIRA_SOURCE_FIELD=Источник
JIRA_IS_CRIT_ALERT_FIELD=Был ли крит алерт?
# Date-time picker field that receives the alert arrival time. Optional; leave
# empty to skip. The dd.MM.yyyy HH:mm shown in Jira is only a display format.
JIRA_START_FIELD=Начало
# Date-time picker field that receives false/expected reaction time, and valid
# incident checkmark reaction time on the bot's incident message. Optional.
JIRA_END_FIELD=Окончание
# Numeric field that receives the incident "time to fix" in MINUTES, computed
# from the incident creation time to its end time when it is closed. Optional;
# resolved by name (or pass a customfield_NNNNN id) like the other fields.
JIRA_TIME_TO_FIX_FIELD=Время устранения
# Issue-link type used to link a repeated ("expected") alert to its root alert
# as "is child of". Matched against the link type's inward/outward description or
# name via GET /rest/api/2/issueLinkType, then created with the repeat as the
# child. Set to whatever your Jira instance calls that link type. Optional.
JIRA_REPEAT_LINK_INWARD=is child of

DATABASE_URL=sqlite:///./mattermost_jira_bot.db
INCIDENT_TIMEZONE=Europe/Moscow

# --- Read-only / shadow mode (run alongside prod, change nothing) ---
# When true: suppress every Jira/Mattermost write and mirror what the bot WOULD
# do into MATTERMOST_AUDIT_CHANNEL_ID instead; Jira keys become ADS-TEST stubs.
# See docs/read-only.md. The audit channel MUST be dedicated (distinct from the
# alert/incident/test/ops channels) or startup fails. Give the shadow its own
# DATABASE_URL and its own bot account (member of every channel it reads).
READ_ONLY_MODE=false
MATTERMOST_AUDIT_CHANNEL_ID=
# Optional extra channels the shadow treats as alert/incident channels, so you
# can push test traffic without touching the real ones (real channels keep their
# real Jira link; test channels get the ADS-TEST stub).
MATTERMOST_TEST_ALERT_CHANNEL_ID=
MATTERMOST_TEST_INCIDENT_CHANNEL_ID=
# uvicorn bind (defaults 0.0.0.0:8080); set PORT to run a shadow next to prod.
HOST=0.0.0.0
PORT=8080

# Optional OpenAI-compatible LLM endpoint for postmortem generation from
# incident-channel threads after a checkmark reaction.
LLM_BASE_URL=https://corellm.wb.ru/deepseek/v1
LLM_API_TOKEN=
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4000
LLM_THREAD_MAX_CHARS=24000
# Optional prompt overrides. Unset → the single built-in template is used.
# Both the postmortem (Jira comment) and the in-thread summary share one template
# and the same placeholders, substituted verbatim:
#   {thread_url} {participants} {postmortem_author} {transcript}
# (legacy postmortem files using {incident_thread_url} still work — it aliases {thread_url})
# Prefer the *_FILE variant for these large multi-line prompts: this .env loader
# is line-based and would keep only the first line of an inline value. The file
# path wins over the inline var if both are set. Both can also be edited at
# runtime in the admin UI (Settings tab); a DB override there wins over env.
# LLM_POSTMORTEM_PROMPT_FILE=/etc/mm-jira-bot/postmortem_prompt.txt
# LLM_SUMMARY_PROMPT_FILE=/etc/mm-jira-bot/summary_prompt.txt
# LLM_POSTMORTEM_PROMPT=
# LLM_SUMMARY_PROMPT=
# Stream the completion (SSE) so long generations don't hit the read timeout.
# Set to false only if the endpoint/proxy does not support streaming. When true,
# the summary is also written into the thread live as it generates.
LLM_STREAM=true
# Throttle for live summary edits while streaming: re-render the thread message at
# most once per interval OR every N new characters (whichever comes first).
LLM_STREAM_EDIT_INTERVAL_SECONDS=1.5
LLM_STREAM_EDIT_MIN_CHARS=80
# Per-chunk read timeout in seconds while streaming (whole-response budget when
# streaming is disabled). Connect timeout is fixed at 10s.
LLM_READ_TIMEOUT=120

# Optional hardening and runtime tuning.
MATTERMOST_SLASH_TOKEN=
# Public base URL of this bot, used to build callback URLs for the interactive
# action blocks: validity menu, incident/summary buttons, and feedback dialog.
# Leave empty to disable the blocks and keep only the emoji-reaction fallback.
SERVICE_PUBLIC_URL=
# Interactive button/menu cards (alert card, manual-incident card, feedback) are
# OFF by default — the bot runs in emoji-only mode. Set to true (and configure
# SERVICE_PUBLIC_URL) to enable the cards. Default false.
INTERACTIVE_BUTTONS_ENABLED=false
# Set to false to stop posting the on-call SRE cheat-sheet (a reactions reminder)
# under each firing-alert, manual-incident and alert-originated incident thread.
# Default true.
DUTY_HELP_ENABLED=true
# Reactions that set the Jira "Валидность" field. In the ALERT channel they are
# lightweight (field + thread reply only): :man_gesturing_no: -> Ложный,
# :arrows_counterclockwise: -> Ожидаемый. In the INCIDENT channel the same
# reactions also close the incident and generate the postmortem (like ✅).
MATTERMOST_FALSE_INCIDENT_REACTION_NAME=man_gesturing_no
MATTERMOST_EXPECTED_INCIDENT_REACTION_NAME=arrows_counterclockwise
# Reaction that posts a thread summary (LLM, no Jira), like the 📝 Саммари button.
# Works in any thread (alert/incident/manual). Default :memo:.
MATTERMOST_SUMMARY_REACTION_NAME=memo
# Optional allowlist: only these Mattermost logins/groups' reactions/button
# clicks are acted on (comma- or semicolon-separated; a leading @ is fine).
# Mix logins and group names freely, e.g. "ivanov, sre-team": each entry is
# tried as a login first, the rest as a Mattermost group expanded to its members.
# The bot resolves them at startup and every MATTERMOST_AUTHORIZED_REFRESH_SECONDS.
# Empty = act on everyone. Feedback is always open to all. If the first
# resolution fails entirely the gate stays open (fail-open).
MATTERMOST_AUTHORIZED_USERNAMES=
# How often (seconds) to re-resolve the allowlist so group membership changes
# propagate. Default 300 (~5 min). A transient refresh failure keeps the last
# known-good set instead of clobbering it.
MATTERMOST_AUTHORIZED_REFRESH_SECONDS=300
# Optional on-call mention. Put the full text, e.g. ":look: @sre-ads-duty".
# Pings the duty group in two places: (1) a manual incident in the incident
# channel — above the "Создать задачу" card (interactive) or as a standalone
# thread reply (emoji-only, no SERVICE_PUBLIC_URL or INTERACTIVE_BUTTONS_ENABLED=
# false); (2) a firing alert in the alert channel — above the boxed "Создана
# задача" notice (resolved alerts never create issues, so they are not pinged).
# Goes in the message body so the @group ping actually fires. Empty = no ping.
MATTERMOST_DUTY_MENTION=
LOG_LEVEL=INFO
# LOG_FORMAT: json (structured, one JSON object per line) or text (compact,
# human-readable "time LEVEL event key=value" lines).
LOG_FORMAT=json
API_RETRY_ATTEMPTS=4
API_RETRY_BASE_DELAY_SECONDS=0.5
PENDING_WORK_INTERVAL_SECONDS=30
BACKFILL_RECENT_POSTS_LIMIT=0
ENABLE_BACKFILL_ON_STARTUP=false

# Admin UI + API на том же HTTP-порту, что и бот. URL: http://localhost:8080/admin
# Защита — единый Bearer-токен ADMIN_UI_TOKEN (один на всех, без идентичности
# пользователей), поэтому держи сервис за reverse proxy / firewall.
ADMIN_UI_ENABLED=false
# Bearer-токен для /admin/api/* и логина в UI. Обязателен при ADMIN_UI_ENABLED=true.
ADMIN_UI_TOKEN=replace-with-strong-random-token
# Опционально: реальный Mattermost user id, которому приписываются действия
# жизненного цикла, запущенные из UI (confirm/end/postmortem/...). Пусто →
# действия помечаются меткой "admin-ui".
ADMIN_MM_USER_ID=

# --- Self-health observability (bot ops channel + Prometheus metrics) ---
# MATTERMOST_OPS_CHANNEL_ID: optional channel for the bot's OWN health. Two feeds
# are posted there: (1) every ERROR-level event (websocket drops, pending-work
# failures, Jira/LLM errors, preflight) as a red attachment; (2) every newly
# created Jira issue as a blue "Создана задача" attachment with a link back to its
# source thread/message. This is NOT the Grafana alert channel
# (MATTERMOST_ALERT_CHANNEL_ID). Empty = no ops posting (errors still go to logs).
# The bot must be a member with write access.
MATTERMOST_OPS_CHANNEL_ID=
# Per-event cooldown (seconds): a repeat of the same event is suppressed within
# this window so an error storm can't flood the channel. Default 300.
MATTERMOST_OPS_COOLDOWN_SECONDS=300
# Prometheus /metrics endpoint, served on the bot's HTTP port (8080). Enabled by
# default (Prometheus is meant to be scraped). The endpoint has no auth,
# so rely on network isolation. Set false to remove the endpoint entirely.
METRICS_ENABLED=true
