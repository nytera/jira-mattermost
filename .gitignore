# Секреты / локальные env — НИКОГДА не коммитить реальные значения.
# Единственный отслеживаемый env — шаблон .env.example (только плейсхолдеры).
.env
.env.*
.env_*
*.env
!.env.example

# Прочие секреты/ключи
*.pem
*.key
*.p12
*.pfx
secrets/

.pytest_cache/
__pycache__/
*.pyc
*.db
.venv/
dist/
build/
*.egg-info/
.coverage
htmlcov/
docker-compose.yml

# Admin UI (web_ui): Node-зависимости и билд-артефакты не коммитим — фронт
# собирается в multi-stage Docker, а admin_static/ генерируется из web_ui/dist.
web_ui/node_modules/
web_ui/dist/
src/mm_jira_bot/admin_static/

# macOS
.DS_Store

# uv lock-файл — проект ставится через pip (`pip install -e ".[test]"`), uv.lock не отслеживаем.
uv.lock

# Claude Code: локальные настройки не коммитим; общие агенты в .claude/agents/ — да.
.claude/settings.local.json
