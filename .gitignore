# Секреты / локальные env — НИКОГДА не коммитить реальные значения.
# Единственный отслеживаемый env — шаблон .env.example (только плейсхолдеры).
.env
.env.*
.env_*
*.env
!.env.example

# Прочие секреты/ключи
*.pem
*.key
*.p12
*.pfx
secrets/

.pytest_cache/
__pycache__/
*.pyc
*.db
.venv/
dist/
build/
*.egg-info/
.coverage
htmlcov/
